{
  "name": "crossposthelper",
  "version": "0.2.129",
  "description": "Local-first image library and cross-posting helper for artists.",
  "homepage": "https://valerie-4659.itch.io/crossposthelper",
  "author": {
    "name": "Valerie"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:build": "npm run build && electron-builder --mac --win --linux",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:win": "npm run build && electron-builder --win",
    "tauri": "tauri",
    "tauri:build:app": "tauri build --bundles app",
    "release": "node scripts/release.cjs",
    "release:itch": "node scripts/publish-itch-local.cjs",
    "release:package-local": "node scripts/package-local-release.cjs",
    "release:notify-discord": "node scripts/notify-discord.cjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@tauri-apps/plugin-sql": "^2.3.0",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.2.6",
    "sql.js": "^1.12.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.4",
    "vue-tsc": "^2.1.10"
  },
  "build": {
    "appId": "com.crossposthelper.desktop",
    "productName": "Crosspost Helper",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/database/migrations/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "chrome-extension",
        "to": "chrome-extension"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "crossposthelpericon.png",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "crossposthelpericon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "crossposthelpericon.png",
      "category": "Graphics",
      "maintainer": "Valerie <crossposthelper@localhost>"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
