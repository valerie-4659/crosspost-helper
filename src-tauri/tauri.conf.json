{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crosspost Helper",
  "version": "0.1.0",
  "identifier": "com.crossposthelper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Crosspost Helper",
        "width": 1320,
        "height": 860,
        "minWidth": 1060,
        "minHeight": 720,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:crossposthelper.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
