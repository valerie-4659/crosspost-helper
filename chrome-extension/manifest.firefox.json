{
  "manifest_version": 3,
  "name": "Crosspost Helper Bridge",
  "version": "0.1.0",
  "description": "Post images from Crosspost Helper to X, Bluesky, DeviantArt, and CivitAI without an API.",
  "browser_specific_settings": {
    "gecko": {
      "id": "crossposthelper@valerie.app",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1:27842/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://bsky.app/*",
    "https://www.deviantart.com/*",
    "https://civitai.com/*",
    "https://civitai.red/*"
  ],
  "background": {
    "scripts": ["background/worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content/bridge.js", "content/adapters/x.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://bsky.app/*"],
      "js": ["content/bridge.js", "content/adapters/bluesky.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.deviantart.com/*"],
      "js": ["content/bridge.js", "content/adapters/deviantart.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://civitai.com/*", "https://civitai.red/*"],
      "js": ["content/bridge.js", "content/adapters/civitai.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Crosspost Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
